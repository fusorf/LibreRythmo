{
  "name": "librerythmo",
  "productName": "LibreRythmo",
  "version": "2.6.1",
  "description": "LibreRythmo — bande rythmo libre pour le doublage",
  "author": "fusorf",
  "license": "GPL-3.0-or-later",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "node scripts/make-buildinfo.js && electron-packager . LibreRythmo --platform=win32 --arch=x64 --out=dist --icon=assets/icon.ico --overwrite --no-asar --ignore=\"^/media($|/)\" --ignore=\"^/dist($|/)\" --ignore=\"^/scripts($|/)\"",
    "dist": "node scripts/make-buildinfo.js && electron-builder --publish never"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "electron": "^36.0.0",
    "electron-builder": "^26.15.3",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  },
  "build": {
    "appId": "io.github.fusorf.librerythmo",
    "productName": "LibreRythmo",
    "asar": false,
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!media${/*}",
      "!dist${/*}",
      "!dist-installer${/*}",
      "!cache${/*}",
      "!docs${/*}",
      "!scripts${/*}",
      "!build${/*}",
      "!.github${/*}",
      "!**/*.{md,bundle,map}",
      "!.gitignore"
    ],
    "win": {
      "target": ["nsis", "zip"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "build/icon.png",
      "identity": null,
      "category": "public.app-category.video",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "linux": {
      "target": ["AppImage", "deb", "pacman"],
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "synopsis": "Bande rythmo libre pour le doublage",
      "maintainer": "fusorf <fusorf@users.noreply.github.com>",
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
